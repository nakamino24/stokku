{
  "name": "stokku-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Stokku monorepo - Rebuilt project management suite",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@8.6.0",
  "scripts": {
    "build": "turbo run build",
    "vercel-build": "turbo run build --filter=@stokku/database --filter=@stokku/api --filter=@stokku/web",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @stokku/web test:e2e",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,md,css,scss,html,json}\"",
    "deploy": "bash scripts/deploy.sh",
    "deploy:staging": "bash scripts/deploy.sh staging"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^1.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@stokku/database": "workspace:^"
  }
}