    "next": "13.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.82.0",
    "react-icons": "^5.7.0",
    "swr": "^2.4.2",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "18.15.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "autoprefixer": "^10.5.4",
    "eslint": "8.0.0",
    "eslint-config-next": "13.4.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "5.4.5"
