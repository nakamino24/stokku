{
  "name": "@stokku/web",
  "version": "0.1.0",
  "private": true,
  "description": "Stokku web application",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --skipLibCheck",
